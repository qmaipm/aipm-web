# 部署环境变量示例(Docker 构建时通过 --build-arg 注入,见 Dockerfile / docker-compose.yml)
#
# SITE_ENV  控制是否允许搜索引擎收录:
#   production -> robots 允许收录、输出 sitemap
#   其它(如 test) -> robots 整站 Disallow,避免测试站被索引
#
# SITE_URL  站点对外绝对地址,用于 metadataBase / canonical / OG / sitemap
#
# 生产:
#   SITE_ENV=production
#   SITE_URL=https://www.aipm.cn
#
# 测试:
#   SITE_ENV=test
#   SITE_URL=https://t1816-www.aipm.cn
