# 部署环境变量示例(Docker 构建时通过 --build-arg 注入,见 Dockerfile / docker-compose.yml)
#
# SITE_ENV  控制是否允许搜索引擎收录:
#   production -> robots 允许收录、输出 sitemap
#   其它(如 test) -> robots 整站 Disallow,避免测试站被索引
#
# SITE_URL  站点对外绝对地址,用于 metadataBase / canonical / OG / sitemap
#
# 生产:
#   SITE_ENV=production
#   SITE_URL=https://www.aipm.cn
#
# 测试:
#   SITE_ENV=test
#   SITE_URL=https://t1816-www.aipm.cn
#
# ============================================================
# 官网表单邮件通知 — 阿里云企业邮箱 SMTP(由 app/api/contact 使用)
# 真实值请放在本地 .env.local(已被 .gitignore 忽略),切勿提交密码。
# ============================================================
SMTP_HOST=smtp.qiye.aliyun.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
MAIL_TO=
MAIL_CC=

# 微信公众号文章拉取(由 lib/wechat.ts 使用,/news 页面)
# 真实值放 .env.local;公众号需已认证+有发布权限,且服务器出口 IP 加入公众号 IP 白名单
WECHAT_APPID=
WECHAT_APPSECRET=
